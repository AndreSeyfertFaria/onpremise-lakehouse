# Streaming stack environment variables

# PostgreSQL source system credentials (must match source_system/.env)
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=logistics_db
POSTGRES_HOST=postgres-source

# LocalStack / AWS target credentials (must match infra/.env)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Kafka Connect REST API port
CONNECT_REST_PORT=8083
