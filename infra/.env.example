# LocalStack / AWS Configuration
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
LOCALSTACK_AUTH_TOKEN=your_auth_token_here

# Iceberg Catalog (Postgres)
ICEBERG_CATALOG_USER=iceberg
ICEBERG_CATALOG_PASSWORD=iceberg
ICEBERG_CATALOG_DB=iceberg
ICEBERG_CATALOG_HOST=iceberg-catalog
ICEBERG_CATALOG_PORT=5432

# Airflow Configuration
AIRFLOW_ADMIN_USER=your_airflow_admin_user
AIRFLOW_ADMIN_PASSWORD=your_airflow_admin_password
AIRFLOW__WEBSERVER__SECRET_KEY=generate_secure_key_here
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow

# Connection Details
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_USER=admin
TRINO_CATALOG=iceberg
TRINO_SCHEMA=bronze
AIRFLOW_CONN_TRINO_DBT=trino://admin@trino:8080/iceberg/bronze

# dbt Configuration
DBT_PROJECT_PATH=/opt/airflow/dbt
